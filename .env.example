# Copia este archivo como .env y rellena los valores

# Base de datos PostgreSQL (en producción usa la URL de Neon, PlanetScale, etc.)
DATABASE_URL="postgresql://usuario:password@host:5432/nombre_db"

# NextAuth — genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui"

# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary — para subida de imágenes (cuenta gratuita en cloudinary.com)
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
